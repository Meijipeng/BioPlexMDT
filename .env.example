# Main service
BIOPLEX_SERVICE_KEY=YOUR_SERVICE_KEY
BIOPLEX_SERVICE_URL=https://your-service.example/v1
BIOPLEX_SERVICE_MODEL=default-chat-model

# Embedding service
BIOPLEX_EMBEDDING_KEY=YOUR_EMBEDDING_KEY
BIOPLEX_EMBEDDING_URL=https://your-embedding-service.example/v1
BIOPLEX_EMBEDDING_MODEL=text-embedding-3-small

# Optional retrieval services
BIOPLEX_GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
BIOPLEX_GOOGLE_CSE_ID=YOUR_GOOGLE_CSE_ID
BIOPLEX_PUBMED_EMAIL=your_email@example.com
BIOPLEX_PUBMED_API_KEY=YOUR_PUBMED_API_KEY
BIOPLEX_COHERE_API_KEY=YOUR_COHERE_API_KEY

# Local retrieval data
BIOPLEX_CHROMA_DB_DIR=chroma_db
BIOPLEX_DATA_DIR=data
BIOPLEX_CHROMA_COLLECTION=gbm_rag
BIOPLEX_FACTS_COLLECTION=gbm_facts
BIOPLEX_CHUNK_SIZES=128,512,1024
BIOPLEX_CHUNK_OVERLAP_RATIO=0.15
BIOPLEX_EMBED_BATCH_SIZE=64
BIOPLEX_INDEX_BATCH_SIZE=100

# Tool environments and paths
BIOPLEX_MAIN_TOOL_PATH=src/gbm_agent
BIOPLEX_GIGATIME_CONDA_ENV=gigatime_check_1
BIOPLEX_GIGATIME_TOOL_PATH=tools/GigaTIME
BIOPLEX_GIGATIME_EXTERNAL_SCRIPT=
BIOPLEX_WSL_DISTRO=Ubuntu
BIOPLEX_RASPR_TOOL_PATH=tools/raspr
BIOPLEX_RASPR_SCRIPT_PATH=tools/raspr/run_case_all.sh
BIOPLEX_RASPR_EXTERNAL_SCRIPT=
BIOPLEX_RASPR_RUNS_ROOT=tools/raspr/runs
BIOPLEX_NNUNET_RESULTS=nnUNet_folders/results
BIOPLEX_NNUNET_RAW=nnUNet_folders/raw
BIOPLEX_NNUNET_PREPROCESSED=nnUNet_folders/preprocessed
BIOPLEX_ROAM_ROOT=tools/ROAM
BIOPLEX_ROAM_EXTERNAL_ROOT=
BIOPLEX_ROAM_CONDA_ENV=roam
BIOPLEX_ROAM_ASSETS=tools/ROAM/assets
BIOPLEX_ROAM_RESULTS=tools/ROAM/results
BIOPLEX_SCRNA_CONDA_ENV=scMulan
BIOPLEX_SCRNA_TOOLS_DIR=tools/scrna
BIOPLEX_SCRNA_EXTERNAL_PIPELINE=
